{% comment %}
  GiftCart AI Chatbot Widget
  This app embed loads the chatbot widget on all pages
{% endcomment %}

<!-- DEBUG: GiftCart Chatbot is loading -->
<div id="giftcart-debug" style="position: fixed; top: 0; left: 0; background: red; color: white; padding: 5px; z-index: 999999;">
  GiftCart Extension Loaded!
</div>

<script>
  window.GIFTCART_CHAT_CONFIG = {
    apiUrl: {{ block.settings.api_url | json }},
    shop: {{ shop.permanent_domain | json }},
    theme: {
      primaryColor: {{ block.settings.primary_color | json }},
      position: {{ block.settings.position | json }}
    }
  };
  console.log('GiftCart Config:', window.GIFTCART_CHAT_CONFIG);
</script>

<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "GiftCart Chatbot",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "default": "https://bot.api.vurve.ai/api/v1/talk",
      "info": "Your backend API endpoint URL"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#0284c7"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        }
      ],
      "default": "bottom-right"
    }
  ]
}
{% endschema %}
