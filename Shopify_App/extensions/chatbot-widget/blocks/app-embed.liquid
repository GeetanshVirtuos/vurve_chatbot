{% comment %}
  GiftCart AI Chatbot Widget
  This app embed loads the chatbot widget on all pages
{% endcomment %}

<script>
  window.GIFTCART_CHAT_CONFIG = {
    apiUrl: {{ block.settings.api_url | json }},
    shop: {{ shop.permanent_domain | json }},
    theme: {
      primaryColor: {{ block.settings.primary_color | json }},
      position: {{ block.settings.position | json }}
    }
  };
</script>

{{ 'widget.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "GiftCart Chatbot",
  "target": "body",
  "javascript": "widget.js",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "default": "https://your-backend.com/api/v1/talk",
      "info": "Your backend API endpoint URL"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#0284c7"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        }
      ],
      "default": "bottom-right"
    }
  ]
}
{% endschema %}
