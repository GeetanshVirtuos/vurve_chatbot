SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=write_products,read_customers
# Get this from Cloudflare Tunnel (see CLOUDFLARE_TUNNEL.md)
# Example: https://abc-123.trycloudflare.com
HOST=https://your-cloudflare-tunnel-url.trycloudflare.com

# Backend API Configuration (your FastAPI server)
BACKEND_API_URL=https://bot.api.vurve.ai/api/v1/talk

# Database
DATABASE_URL=file:./dev.db
